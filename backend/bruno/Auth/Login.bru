meta {
  name: Login con Email
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "estudiante@inova.edu.ar",
    "password": "Password123!"
  }
}

script:post-response {
  if (res.body && res.body.idToken) {
    bru.setEnvVar("token", res.body.idToken);
  }
}

