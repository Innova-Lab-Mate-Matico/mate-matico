meta {
  name: Registro con Email
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "estudiante@inova.edu.ar",
    "password": "Password123!",
    "displayName": "Estudiante Prueba"
  }
}

script:post-response {
  if (res.body && res.body.idToken) {
    bru.setEnvVar("token", res.body.idToken);
  }
}

