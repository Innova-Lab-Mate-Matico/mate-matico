# Servidor
PORT=3000
NODE_ENV=development
# Orígenes del front (separados por coma). Agregá la URL de producción del otro equipo.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://mate-matico.vercel.app,https://mate-matico.vercel.app/

# Firebase — proyecto (Firebase Console → Configuración → General)
FIREBASE_PROJECT_ID=talento14bd
# Misma apiKey que en firebaseConfig del front (campo apiKey)
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=talento14bd.firebaseapp.com

# Firebase — cuenta de servicio (Console → Cuentas de servicio → Generar clave)
FIREBASE_TYPE=service_account
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=
FIREBASE_UNIVERSE_DOMAIN=googleapis.com
